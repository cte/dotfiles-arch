configuration {
    modi: "drun,run,window";
    show-icons: true;
    display-drun: "app";
    display-run: "run";
    display-window: "win";
    drun-display-format: "{name}";
    window-format: "{w}{t}";
    icon-theme: "Papirus-Dark";
    font: "GeistMono Nerd Font Mono 10";
}

@theme "theme.rasi"
